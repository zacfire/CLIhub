      "id": "gh",
      "name": "GitHub CLI",
      "description": "GitHub's official CLI — PRs, issues, code review, repo management. The most-used CLI by AI agents.",
      "repo": "https://github.com/cli/cli",
      "tags": ["git", "github", "code", "pr", "issues", "code-review", "devops"],
      "official": true,
      "install": {
        "brew": "brew install gh",
        "winget": "winget install --id GitHub.cli",
        "apt": "apt install gh"
      },
      "commands_count": 100,
      "key_commands": [
        "gh pr create --title <title> --body <body>",
        "gh pr list --json title,url",
