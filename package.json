{
  "name": "@zacfire/clihub",
  "version": "1.2.0",
  "description": "CLI discovery service for AI Agents — find the right CLI tool for any task",
  "type": "module",
  "bin": {
    "clihub": "dist/cli.js",
    "clihub-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/mcp.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacfire/CLIhub.git"
  },
  "keywords": ["cli", "agent", "ai", "mcp", "discovery", "tools"],
  "author": "zacfire",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zacfire/CLIhub/issues"
  },
  "homepage": "https://github.com/zacfire/CLIhub#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "fuse.js": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
